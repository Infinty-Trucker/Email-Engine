# Dispatch OS — production environment template
#
# Copy to .env and fill in real values:
#   cp .env.production.example .env
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

# ── Django core ──────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=__GENERATE_64_CHAR_SECRET__
ALLOWED_HOSTS=dispatch.example.com,api.dispatch.example.com

# Comma-separated list of frontend origins permitted by CORS + CSRF
CORS_ALLOWED_ORIGINS=https://dispatch.example.com
CSRF_TRUSTED_ORIGINS=https://dispatch.example.com

# Set when behind HTTPS (nginx/traefik/cloudflare). Enables HSTS + secure cookies.
USE_HTTPS=True

# Public URL of the React frontend (used to build deep links in emails/Slack)
FRONTEND_URL=https://dispatch.example.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=__GENERATE_STRONG_DB_PASSWORD__
DB_CONN_MAX_AGE=60

# ── Google Workspace (optional — for service-account mailboxes) ──────────────
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/service_account.json
GOOGLE_PUBSUB_TOPIC=projects/your-gcp-project/topics/gmail-dispatch-push

# ── Anthropic (optional — for AI summaries and auto-replies) ─────────────────
# Top up credits at https://console.anthropic.com/settings/billing before enabling.
ANTHROPIC_API_KEY=

# ── Slack (optional — token is also storable via Admin UI) ───────────────────
SLACK_BOT_TOKEN=

# ── AWS S3 (optional — for offloading attachments to durable storage) ────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
