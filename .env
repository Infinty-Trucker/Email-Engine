ALLOWED_HOSTS=localhost,127.0.0.1,api,*
TMS_BACKEND_URL=http://host.docker.internal:8000
TMS_AUTH_CACHE_TTL=60

# ─── Factoring schedule ingest (Email-Engine -> TMS) ─────────────────────────
# Shared secret sent as `X-Service-Token` when the automations dispatcher
# forwards Phoenix Capital schedule PDFs to TMS-Backend's
# /factoring/api/v1/ingest-email/ endpoint.
#
# THIS VALUE MUST MATCH `FACTORING_INGEST_TOKEN` in TMS-Backend/.env
# exactly. Different values = TMS returns 403 = the agent silently can't
# import schedules.
#
# Generate a production value with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
FACTORING_INGEST_TOKEN=6BQunpi8iQt2aN0t3UTrxvOIJ4SF3_0Kcm7G1jdDsFiRHFsxY7cvgLfXfxo5_tm4
